# ============ LiveMap 配置 ============
# 复制此文件为 .env 并填入你的 key

# -------- 火山引擎 Ark（推荐 · 比 Claude 便宜 10-30 倍）--------
# 1. 去 https://console.volcengine.com/ark/region:ark+cn-beijing/apiKey 拿 API Key
# 2. 去 https://console.volcengine.com/ark/region:ark+cn-beijing/endpoint 创建推理接入点
VOLC_API_KEY=
VOLC_ENDPOINT_ID=                              # 如：ep-20250528xxxxx-xxxxx（推荐方式）
# VOLC_MODEL=doubao-1-5-pro-32k-250115         # 或直接用模型名（二选一）

# -------- Anthropic Claude（fallback / 备选）--------
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# -------- 强制指定后端（可选，留空自动选 · 优先火山）--------
# LLM_PROVIDER=volc        # 或 anthropic
